---
import Masthead from '../components/Masthead.astro';
import Footer from '../components/Footer.astro';
import MathJax from '../components/MathJax.astro';
import { site } from '../data/site';
import '../styles/style.css';

const {
  title = site.title,
  description = site.description
} = Astro.props;

const pageTitle = title === site.title ? site.title : `${title} | ${site.title}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{pageTitle}</title>
    <meta name="description" content={description}>
    <link rel="canonical" href={new URL(Astro.url.pathname, site.url)}>
    <link rel="alternate" type="application/rss+xml" title={`${site.title} RSS`} href="/feed.xml">
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ctext y='23' font-size='22' font-family='monospace'%3EA%3C/text%3E%3C/svg%3E">
  </head>
  <body>
    <main class="page">
      <Masthead />
      <slot />
      <Footer />
    </main>
    <MathJax />
  </body>
</html>
